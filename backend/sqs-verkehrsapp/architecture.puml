@startuml
title SQS VerkehrsApp - Backend Architektur (Clean + Resilient)

skinparam packageStyle rectangle
skinparam componentStyle rectangle

actor "User" as User

node "Frontend\nReact / Browser" as Frontend

cloud "Autobahn API\nverkehr.autobahn.de" as AutobahnApi

database "PostgreSQL\nCache DB" as Postgres

package "Spring Boot Backend" {

  package "Adapter In / Web" {
    component "TrafficController" as TrafficController
    component "TrafficResponseDto" as TrafficResponseDto
  }

  package "Application Layer" {
    interface "TrafficQueryUseCase" as TrafficQueryUseCase
    component "TrafficService" as TrafficService

    interface "AutobahnApiPort" as AutobahnApiPort
    interface "RoadEventCachePort" as RoadEventCachePort
  }

  package "Domain Layer" {
    component "RoadEvent" as RoadEvent
    component "Coordinate" as Coordinate
    component "RoadEventType" as RoadEventType
    component "RiskLevel" as RiskLevel
    component "RiskScoreCalculator" as RiskScoreCalculator
  }

  package "Adapter Out / Autobahn API" {

    component "ResilientAutobahnApiAdapter\n(Proxy: Retry, CircuitBreaker, Fallback)" as ResilientAdapter

    component "AutobahnApiClient\n(HTTP Client)" as AutobahnApiClient
    component "AutobahnApiMapper" as AutobahnApiMapper

    component "External DTOs\nWarningDto, ClosureDto,\nRoadworkDto, ChargingStationDto" as ExternalDtos
  }

  package "Adapter Out / Persistence" {
    component "RoadEventCacheAdapter" as CacheAdapter
    component "CachedRoadEventEntity" as CacheEntity
    component "CachedRoadEventRepository" as CacheRepo
  }

  package "Config" {
    component "WebClientConfig" as WebClientConfig
    component "AutobahnApiProperties" as AutobahnApiProperties
  }
}

' --- Flow ---
User --> Frontend
Frontend --> TrafficController : HTTP / REST

TrafficController --> TrafficQueryUseCase
TrafficController --> TrafficResponseDto

TrafficService ..|> TrafficQueryUseCase
TrafficService --> AutobahnApiPort

' --- Ports Implementation ---
ResilientAdapter ..|> AutobahnApiPort
CacheAdapter ..|> RoadEventCachePort

' --- Proxy Layer ---
ResilientAdapter --> AutobahnApiClient
ResilientAdapter --> RoadEventCachePort

' --- External API ---
AutobahnApiClient --> AutobahnApiMapper
AutobahnApiClient --> ExternalDtos
AutobahnApiClient --> AutobahnApi : WebClient / HTTPS

' --- Mapping ---
AutobahnApiMapper --> RoadEvent
AutobahnApiMapper --> Coordinate
AutobahnApiMapper --> RiskScoreCalculator

' --- Domain ---
RoadEvent --> Coordinate
RoadEvent --> RoadEventType
RoadEvent --> RiskLevel
RiskScoreCalculator --> RiskLevel

' --- Cache ---
CacheAdapter --> CacheRepo
CacheRepo --> CacheEntity
CacheAdapter --> Postgres

' --- Config ---
WebClientConfig --> AutobahnApiClient
AutobahnApiProperties --> WebClientConfig

@enduml
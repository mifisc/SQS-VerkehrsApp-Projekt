@startuml
title C4 Component Diagram - SQS VerkehrsApp Backend

!include <C4/C4_Component>

LAYOUT_WITH_LEGEND()

Person(user, "User", "Nutzt die VerkehrsApp im Browser")

System_Ext(autobahnApi, "Autobahn API", "Externes Fremdsystem für Warnungen, Baustellen und Sperrungen")
SystemDb_Ext(postgres, "PostgreSQL Cache DB", "Speichert zuletzt erfolgreich geladene Verkehrsdaten als Fallback")

Container(frontend, "Frontend", "React / Browser", "Zeigt Verkehrsdaten für ausgewählte Autobahnen an")

Container_Boundary(backend, "Spring Boot Backend") {

    Component(controller, "TrafficController", "REST Controller", "Nimmt HTTP-Anfragen vom Frontend entgegen")

    Component(useCase, "TrafficQueryUseCase", "Input Port / Interface", "Definiert die fachliche Abfrage von Verkehrsdaten")

    Component(service, "TrafficService", "Application Service", "Koordiniert den Use Case und bleibt unabhängig von externen Systemen")

    Component(apiPort, "AutobahnApiPort", "Output Port / Interface", "Abstraktion für den Zugriff auf Verkehrsdaten")

    Component(cachePort, "RoadEventCachePort", "Output Port / Interface", "Abstraktion für Lesen und Schreiben des lokalen Caches")

    Component(resilientAdapter, "ResilientAutobahnApiAdapter", "Proxy / Outbound Adapter", "Kapselt Retry, Circuit Breaker, Cache-Speicherung und Fallback")

    Component(apiClient, "AutobahnApiClient", "HTTP Client", "Ruft die externe Autobahn API über WebClient auf")

    Component(mapper, "AutobahnApiMapper", "Mapper", "Übersetzt externe DTOs in Domain-Objekte")

    Component(cacheAdapter, "RoadEventCacheAdapter", "Persistence Adapter", "Speichert und lädt Verkehrsdaten aus PostgreSQL")

    Component(repository, "CachedRoadEventRepository", "Spring Data JPA Repository", "Technischer Zugriff auf die Cache-Tabelle")

    Component(domain, "Domain Model", "RoadEvent, Coordinate, RoadEventType, RiskLevel", "Fachliche Verkehrsdaten unabhängig von Frameworks und Fremdsystemen")
}

Rel(user, frontend, "nutzt")
Rel(frontend, controller, "ruft auf", "HTTP / REST")

Rel(controller, useCase, "nutzt")
Rel(useCase, service, "wird implementiert von")
Rel(service, apiPort, "nutzt")

Rel(apiPort, resilientAdapter, "wird implementiert von")
Rel(resilientAdapter, apiClient, "ruft externe API über Client auf")
Rel(resilientAdapter, cachePort, "nutzt für Cache und Fallback")

Rel(apiClient, autobahnApi, "lädt Verkehrsdaten", "HTTPS / WebClient")
Rel(apiClient, mapper, "übergibt externe DTOs")
Rel(mapper, domain, "erstellt")

Rel(cachePort, cacheAdapter, "wird implementiert von")
Rel(cacheAdapter, repository, "nutzt")
Rel(repository, postgres, "liest/schreibt", "JDBC / JPA")
Rel(cacheAdapter, domain, "mappt Entity zu Domain")

@enduml